<script>
    // --- Gestion du Menu Mobile ---
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    menuToggle.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        if (mobileMenu.classList.contains('hidden')) {
            menuIcon.textContent = 'menu';
        } else {
            menuIcon.textContent = 'close';
        }
    });

    // --- Gestion du Carrousel Images (Philosophy) ---
    const container = document.getElementById('sliderContainer');
    const dot1 = document.getElementById('dot-1');
    const dot2 = document.getElementById('dot-2');

    function scrollToSlide(direction) {
        if (!container) return;
        const width = container.clientWidth;
        
        if (direction === 'right') {
            if (container.scrollLeft + width >= container.scrollWidth - 10) {
                container.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
                container.scrollBy({ left: width, behavior: 'smooth' });
            }
        } else {
            if (container.scrollLeft <= 10) {
                container.scrollTo({ left: container.scrollWidth, behavior: 'smooth' });
            } else {
                container.scrollBy({ left: -width, behavior: 'smooth' });
            }
        }
    }

    // Gestion de l'état des points (dots) lors du scroll
    if (container) {
        container.addEventListener('scroll', () => {
            const width = container.clientWidth;
            if (container.scrollLeft >= width / 2) {
                dot1.classList.remove('bg-white');
                dot1.classList.add('bg-white/50');
                dot2.classList.remove('bg-white/50');
                dot2.classList.add('bg-white');
            } else {
                dot1.classList.remove('bg-white/50');
                dot1.classList.add('bg-white');
                dot2.classList.remove('bg-white');
                dot2.classList.add('bg-white/50');
            }
        });

        // Défilement automatique toutes les 5 secondes
        setInterval(() => {
            scrollToSlide('right');
        }, 5000);
    }
</script>

