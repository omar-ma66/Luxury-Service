                            </div>
                            <div class="relative border-b-2 border-gray-300 focus-within:border-amber-500 transition-all py-2">
                                <input required="required" name="lastname" type="text" placeholder=" " class="block w-full appearance-none bg-transparent focus:outline-none peer text-gray-900">
                                <label class="absolute bottom-2 left-0 text-gray-500 peer-placeholder-shown:text-base peer-placeholder-shown:translate-y-0 peer-focus:-translate-y-6 peer-focus:text-sm peer-focus:text-amber-500 transition-all transform -translate-y-6 text-sm">Last name</label>
                            </div>
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="relative border-b-2 border-gray-300 focus-within:border-amber-500 transition-all py-2">
                                <input required="required" name="email" type="email" placeholder=" " class="block w-full appearance-none bg-transparent focus:outline-none peer text-gray-900">
                                <label class="absolute bottom-2 left-0 text-gray-500 peer-placeholder-shown:text-base peer-placeholder-shown:translate-y-0 peer-focus:-translate-y-6 peer-focus:text-sm peer-focus:text-amber-500 transition-all transform -translate-y-6 text-sm">Email</label>
                            </div>
                            <div class="relative border-b-2 border-gray-300 focus-within:border-amber-500 transition-all py-2">
                                <input required="required" name="phone" type="tel" placeholder=" " class="block w-full appearance-none bg-transparent focus:outline-none peer text-gray-900">
                                <label class="absolute bottom-2 left-0 text-gray-500 peer-placeholder-shown:text-base peer-placeholder-shown:translate-y-0 peer-focus:-translate-y-6 peer-focus:text-sm peer-focus:text-amber-500 transition-all transform -translate-y-6 text-sm">Phone Number</label>
                            </div>
                        </div>

                        <div class="relative border-b-2 border-gray-300 focus-within:border-amber-500 transition-all py-2">
                            <textarea name="message" required="required" rows="4" placeholder=" " class="block w-full appearance-none bg-transparent focus:outline-none peer text-gray-900 resize-none"></textarea>
                            <label class="absolute top-2 left-0 text-gray-500 peer-placeholder-shown:text-base peer-placeholder-shown:translate-y-0 peer-focus:-translate-y-6 peer-focus:text-sm peer-focus:text-amber-500 transition-all transform -translate-y-6 text-sm">Message</label>
