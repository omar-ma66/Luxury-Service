<body id="top" class="flex flex-col h-full text-gray-900 antialiased font-sans">

    <header class="absolute inset-x-0 top-0 z-50 bg-black/40 backdrop-blur-md border-b border-white/10">
        <nav class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8" aria-label="Global">
            <div class="flex lg:flex-1">
                <a href="/" class="-m-1.5 p-1.5 text-white font-bold text-xl tracking-widest hover:text-amber-400 transition">
                    LUXURY SERVICES
                </a>
            </div>
            
            <div class="flex lg:hidden">
                <button type="button" id="mobile-menu-open" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-white">
                    <span class="sr-only">Open main menu</span>
                    <i class="fa-solid fa-bars text-2xl"></i>
                </button>
            </div>

            <div class="hidden lg:flex lg:gap-x-8">
                <a href="/" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">Home</a>
                <a href="{{ path('app_jobs') }}" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">Jobs offers</a>
                <a href="{{ path('app_compagny') }}" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">About us</a>
                <a href="{{ path('app_contact') }}" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">Contact</a>
            </div>

            <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:items-center lg:gap-x-6">
                <a href="/templates/auth/login.html" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">Login</a>
                <a href="/templates/auth/register.html" class="rounded-full bg-gradient-to-r from-amber-500 to-amber-600 px-5 py-2 text-sm font-semibold text-white shadow-md hover:from-amber-600 hover:to-amber-700 hover:shadow-lg transition-all duration-200">
                    Sign Up
                </a>
            </div>
        </nav>

        <div id="mobile-menu-wrapper" class="hidden fixed inset-0 z-50 overflow-y-auto bg-gray-900/90 backdrop-blur-lg px-6 py-6 lg:hidden">
            <div class="flex items-center justify-between">
                <a href="/" class="-m-1.5 p-1.5 text-white font-bold text-lg tracking-wider">
                    LUXURY SERVICES
                </a>
                <button type="button" id="mobile-menu-close" class="-m-2.5 rounded-md p-2.5 text-gray-400 hover:text-white">
                    <span class="sr-only">Close menu</span>
                    <i class="fa-solid fa-xmark text-2xl"></i>
                </button>
            </div>
            <div class="mt-8 flow-root">
                <div class="-my-6 divide-y divide-gray-500/20">
                    <div class="space-y-2 py-6">
                        <a href="/" class="-mx-3 block rounded-lg px-3 py-2 text-base font-semibold leading-7 text-white hover:bg-gray-800">Home</a>
                        <a href="{{ path('app_jobs') }}" class="-mx-3 block rounded-lg px-3 py-2 text-base font-semibold leading-7 text-white hover:bg-gray-800">Jobs offers</a>
                        <a href="{{ path('app_compagny') }}" class="-mx-3 block rounded-lg px-3 py-2 text-base font-semibold leading-7 text-white hover:bg-gray-800">About us</a>
                        <a href="{{ path('app_contact') }}" class="-mx-3 block rounded-lg px-3 py-2 text-base font-semibold leading-7 text-white hover:bg-gray-800">Contact</a>
                    </div>
                    <div class="py-6 space-y-3">
                        <a href="/templates/auth/login.html" class="-mx-3 block rounded-lg px-3 py-2 text-base font-semibold leading-7 text-white hover:bg-gray-800">Login</a>
                        <a href="/templates/auth/register.html" class="w-full text-center block rounded-full bg-gradient-to-r from-amber-500 to-amber-600 px-4 py-2.5 text-base font-semibold text-white shadow-sm hover:from-amber-600 hover:to-amber-700">Sign Up</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow">
        
        <section class="relative isolate overflow-hidden bg-gray-900 py-32 sm:py-40">
            <div class="absolute inset-0 -z-10 bg-[url('assets/img/bg3.jpg')] bg-cover bg-center opacity-40"></div>
            <div class="absolute inset-0 -z-10 bg-black/50"></div>
            
            <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center mt-12">
                <h2 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl">Register</h2>
                <p class="mt-3 text-lg leading-8 text-gray-300 tracking-wide">Welcome on board</p>
                
                <nav class="mt-6 flex justify-center space-x-3 text-sm font-medium text-gray-400">
                    <a href="#!" class="hover:text-white transition">Home</a>
                    <span>/</span>
                    <span class="text-amber-400">Register</span>
                </nav>
            </div>
        </section>

        <section class="bg-gray-100 py-20 px-4 sm:px-6 lg:px-8">
            <div class="max-w-md mx-auto bg-white p-8 sm:p-10 rounded-2xl shadow-xl border border-gray-100">
                <h3 class="text-3xl font-black tracking-tight text-gray-900 text-center mb-8">
                    Create a new account
                </h3>

                {{ form_start(registrationForm, {
                    'attr': {
                        'id': 'register-form',
                        'role': 'form',
                        'accept-char': 'UTF-8',
                        'autocomplete': 'off',
                        'data-parsley-validate': true,
                        'class': 'space-y-6'
                    }
                }) }}

                    {# Affichage global des erreurs #}
                    {% if form_errors(registrationForm) %}
                        <div class="p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-r-lg text-sm shadow-sm animate-pulse">
                            {{ form_errors(registrationForm) }}
                        </div>
                    {% endif %}

                    {# Champ Email #}
                    <div class="flex flex-col space-y-1.5">
                        {{ form_label(registrationForm.email, 'Email', {
                            'label_attr': {'class': 'text-sm font-semibold text-gray-700 tracking-wide'}
                        }) }}
                        <div class="relative rounded-md shadow-sm">
                            {{ form_widget(registrationForm.email, {
                                'attr': {
                                    'data-parsley-trigger': 'change',
                                    'data-parsley-error-message': 'A valid email address is required.',
                                    'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-all duration-150 text-base'
                                }
                            }) }}
                        </div>
                        <span class="text-xs text-gray-400 mt-0.5">Type your email address.</span>
                        <div class="text-xs text-red-600 mt-1">{{ form_errors(registrationForm.email) }}</div>
                    </div>

                    {# Champ Mot de passe #}
                    <div class="flex flex-col space-y-1.5">
                        {{ form_label(registrationForm.plainPassword, 'Password', {
                            'label_attr': {'class': 'text-sm font-semibold text-gray-700 tracking-wide'}
                        }) }}
                        <div class="relative rounded-md shadow-sm">
                            {{ form_widget(registrationForm.plainPassword, {
                                'attr': {
                                    'data-parsley-trigger': 'change',
                                    'data-parsley-minlength': '6',
                                    'data-parsley-error-message': 'The password must be at least 6 characters.',
                                    'class': 'w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 pr-12 transition-all duration-150 text-base'
                                }
                            }) }}
                            <button type="button" class="absolute inset-y-0 right-0 flex items-center pr-4 text-gray-400 hover:text-gray-600 focus:outline-none">
                                <i class="fa-solid fa-eye show-password text-lg cursor-pointer"></i>
                            </button>
                        </div>
                        <span class="text-xs text-gray-400 mt-0.5">Type your password.</span>
                        <div class="text-xs text-red-600 mt-1">{{ form_errors(registrationForm.plainPassword) }}</div>
                    </div>

                    {# Case à cocher pour les conditions d'utilisation #}
                    <div class="flex items-start space-x-3 pt-2">
                        <div class="flex items-center h-5">
                            {{ form_widget(registrationForm.agreeTerms, {
                                'attr': {
                                    'class': 'h-5 w-5 text-amber-600 border-gray-300 rounded focus:ring-amber-500 cursor-pointer transition-all duration-150'
                                }
                            }) }}
                        </div>
                        <div class="text-sm leading-5">
                            <label for="{{ registrationForm.agreeTerms.vars.id }}" class="font-medium text-gray-600 cursor-pointer select-none">
                                I have read and I accept the <a href="#!" target="_blank" class="text-amber-600 hover:text-amber-700 hover:underline font-semibold transition">Terms Of Use</a>
                            </label>
                            <div class="text-xs text-red-600 mt-1">{{ form_errors(registrationForm.agreeTerms) }}</div>
                        </div>
                    </div>

                    {# Bouton de soumission #}
                    <button type="submit" class="w-full flex justify-center py-3.5 px-4 border border-transparent rounded-xl shadow-md text-base font-bold text-white bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transition-all duration-200 transform active:scale-[0.99] mt-6">
                        Create an account
                    </button>
                    
                    {# Lien de redirection #}
                    <div class="text-center text-sm pt-4 border-t border-gray-100 mt-6">
                        <a href="/login.html" class="font-semibold text-amber-600 hover:text-amber-700 hover:underline transition">
                            Already have an account? Click here
                        </a>
                    </div>

                {{ form_end(registrationForm) }}
            </div>
        </section>
    </main>

    <footer class="bg-gray-900 text-gray-400 text-center border-t border-gray-800">
        <div class="mx-auto max-w-7xl py-12 px-6 lg:px-8">
            <a href="#top" class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-gradient-to-r from-amber-500 to-amber-600 text-white shadow-xl hover:from-amber-600 hover:to-amber-700 transform hover:-translate-y-1 transition-all duration-200 mb-8">
                <i class="fa-solid fa-chevron-up text-xl"></i>
            </a>

            <div class="flex justify-center space-x-8 mb-8">
                <a href="#!" target="_blank" class="text-gray-400 hover:text-white text-2xl transition"><i class="fab fa-facebook"></i></a>
                <a href="#!" target="_blank" class="text-gray-400 hover:text-white text-2xl transition"><i class="fab fa-linkedin"></i></a>
            </div>

            <hr class="border-gray-800 my-8">

            <p class="text-sm tracking-wide text-gray-400 mb-4">
                © 2026 All rights reserved - by <a href="https://idmkr.io/" target="_blank" class="text-amber-500 hover:underline font-medium">IDMKR</a> - <a href="#!" class="hover:text-white transition">Terms of use</a>
            </p>
            
            <p class="max-w-2xl mx-auto text-xs text-gray-500 leading-relaxed tracking-normal">
                Luxury Services is a leading professional recruitment consultancy specialising in the recruitment of permanent, contract and temporary positions on behalf of the world’s top employers.
            </p>
        </div>

        <div class="bg-gray-950/60 py-6 border-t border-gray-900">
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
                <ul class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm font-medium">
                    <li><a href="/" class="text-gray-400 hover:text-amber-400 transition">Home</a></li>
                    <li><a href="/jobs.html" class="text-gray-400 hover:text-amber-400 transition">Jobs offers</a></li>
                    <li><a href="/about-us.html" class="text-gray-400 hover:text-amber-400 transition">About us</a></li>
                    <li><a href="/contact.html" class="text-gray-400 hover:text-amber-400 transition">Contact</a></li>
                </ul>
            </div>
        </div>
    </footer>

    <script type="text/javascript">
        // Gestion ouverture / fermeture du menu Mobile adaptatif
        const openBtn = document.getElementById('mobile-menu-open');
        const closeBtn = document.getElementById('mobile-menu-close');
        const wrapper = document.getElementById('mobile-menu-wrapper');

        if(openBtn && closeBtn && wrapper) {
            openBtn.addEventListener('click', () => wrapper.classList.remove('hidden'));
            closeBtn.addEventListener('click', () => wrapper.classList.add('hidden'));
        }

        onAppReady(function() {
            $('.preload').remove();
        });
    </script>

</body>
</html>