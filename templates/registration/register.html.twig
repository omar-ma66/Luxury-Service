<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <title>Luxury Services recruitment & services</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="idmkr.io">
    <meta name="csrf-token" content="9Tnm0YBCxgVTxoqI1HzccsU5NuE9RughZmhpzgXn">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="flex flex-col h-full text-gray-900 antialiased font-sans">

    <header class="absolute inset-x-0 top-0 z-50 bg-black/40 backdrop-blur-sm">
        <nav class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8" aria-label="Global">
            <div class="flex lg:flex-1">
                <a href="/" class="-m-1.5 p-1.5 text-white font-bold text-xl tracking-wider">
                    LUXURY SERVICES
                </a>
            </div>
            
            <div class="hidden lg:flex lg:gap-x-8">
                <a href="/" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">Home</a>
                <a href="{{ path('app_jobs') }}" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">Jobs offers</a>
                <a href="{{ path('app_compagny') }}" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">About us</a>
                <a href="{{ path('app_contact') }}" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">Contact</a>
            </div>

            <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:items-center lg:gap-x-6">
                <a href="/templates/auth/login.html" class="text-sm font-semibold leading-6 text-white hover:text-amber-400 transition">Login</a>
                <a href="/templates/auth/register.html" class="rounded-md bg-gradient-to-r from-amber-500 to-amber-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:from-amber-600 hover:to-amber-700 transition">
                    Sign Up
                </a>
            </div>
        </nav>
    </header>

    <main class="flex-grow">
        <section class="relative isolate overflow-hidden bg-gray-900 py-24 sm:py-32 section-padding">
            <div class="absolute inset-0 -z-10 bg-[url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070')] bg-cover bg-center opacity-40"></div>
            
            <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center pt-10">
                <h2 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">Register</h2>
                <p class="mt-4 text-lg leading-8 text-gray-300">Welcome on board</p>
                <nav class="mt-4 flex justify-center space-x-2 text-sm text-gray-400">
                    <a href="#!" class="hover:text-white">Home</a>
                    <span>/</span>
                    <span class="text-amber-400">Register</span>
                </nav>
            </div>
        </section>

        <section class="bg-gray-100 py-16 px-6 lg:px-8">
            <div class="sm:mx-auto sm:w-full sm:max-w-md bg-white p-8 rounded-xl shadow-lg border border-gray-100">
                <h3 class="text-2xl font-bold tracking-tight text-gray-900 text-center mb-8">
                    Create a new account
                </h3>

                {{ form_start(registrationForm, {
                    'attr': {
                        'id': 'register-form',
                        'role': 'form',
                        'accept-char': 'UTF-8',
                        'autocomplete': 'off',
                        'data-parsley-validate': true,
                        'class': 'space-y-6'
                    }
                }) }}

                    {# Affichage global des erreurs #}
                    {% if form_errors(registrationForm) %}
                        <div class="p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">
                            {{ form_errors(registrationForm) }}
                        </div>
                    {% endif %}

                    {# Champ Email #}
                    <div class="flex flex-col space-y-1">
                        {{ form_label(registrationForm.email, 'Email', {
                            'label_attr': {'class': 'text-sm font-medium text-gray-700'}
                        }) }}
                        {{ form_widget(registrationForm.email, {
                            'attr': {
                                'data-parsley-trigger': 'change',
                                'data-parsley-error-message': 'A valid email address is required.',
                                'class': 'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 text-gray-900 transition'
                            }
                        }) }}
                        <span class="text-xs text-gray-400">Type your email address.</span>
                        {{ form_errors(registrationForm.email) }}
                    </div>

                    {# Champ Mot de passe #}
                    <div class="flex flex-col space-y-1">
                        {{ form_label(registrationForm.plainPassword, 'Password', {
                            'label_attr': {'class': 'text-sm font-medium text-gray-700'}
                        }) }}
                        <div class="relative rounded-md shadow-sm">
                            {{ form_widget(registrationForm.plainPassword, {
                                'attr': {
                                    'data-parsley-trigger': 'change',
                                    'data-parsley-minlength': '6',
                                    'data-parsley-error-message': 'The password must be at least 6 characters.',
                                    'class': 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 text-gray-900 pr-10 transition'
                                }
                            }) }}
                            <span class="absolute inset-y-0 right-0 flex items-center pr-3 cursor-pointer text-gray-400 hover:text-gray-600">
                                <i class="fa fa-eye show-password"></i>
                            </span>
                        </div>
                        <span class="text-xs text-gray-400">Type your password.</span>
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>

                    {# Case à cocher (Checkbox fonctionnelle sans aucun conflit) #}
                    <div class="flex items-start space-x-3 pt-1">
                        <div class="flex items-center h-5">
                            {{ form_widget(registrationForm.agreeTerms, {
                                'attr': {
                                    'class': 'h-4 w-4 text-amber-600 border-gray-300 rounded focus:ring-amber-500 cursor-pointer transition'
                                }
                            }) }}
                        </div>
                        <div class="text-sm">
                            <label for="{{ registrationForm.agreeTerms.vars.id }}" class="font-medium text-gray-600 cursor-pointer select-none">
                                I have read and I accept the <a href="#!" target="_blank" class="text-amber-600 hover:text-amber-700 hover:underline font-semibold">Terms Of Use</a>
                            </label>
                            {{ form_errors(registrationForm.agreeTerms) }}
                        </div>
                    </div>

                    {# Bouton de soumission #}
                    <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transition shadow-md mt-4">
                        Create an account
                    </button>
                    
                    {# Lien de redirection #}
                    <div class="text-center text-sm pt-2">
                        <a href="/login.html" class="font-medium text-amber-600 hover:text-amber-700 hover:underline">
                            Already have an account? Click here
                        </a>
                    </div>

                {{ form_end(registrationForm) }}
            </div>
        </section>
    </main>

    <footer class="bg-gray-900 text-gray-400 text-center py-12 px-6 border-t border-gray-800">
        <div class="mx-auto max-w-7xl">
            <a href="#top" class="inline-flex items-center justify-center h-12 w-12 rounded-full bg-amber-500 text-white shadow-lg hover:bg-amber-600 transition mb-6">
                <i class="fa fa-chevron-up"></i>
            </a>

            <div class="flex justify-center space-x-6 mb-6">
                <a href="#!" target="_blank" class="hover:text-white transition"><i class="fab fa-facebook text-xl"></i></a>
                <a href="#!" target="_blank" class="hover:text-white transition"><i class="fab fa-linkedin text-xl"></i></a>
            </div>

            <hr class="border-gray-800 my-6">

            <p class="text-sm mb-4">
                © 2026 All rights reserved - by <a href="https://idmkr.io/" target="_blank" class="text-amber-500 hover:underline">IDMKR</a> - <a href="#!" class="hover:underline">Terms of use</a>
            </p>
            
            <p class="max-w-2xl mx-auto text-xs text-gray-500 leading-relaxed">
                Luxury Services is a leading professional recruitment consultancy specialising in the recruitment of permanent, contract and temporary positions on behalf of the world’s top employers.
            </p>
        </div>
    </footer>

</body>
</html>